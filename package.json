{
  "name": "uni-exam-sys",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "convex": "^1.33.1",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @uni-exam-sys/backend dev",
    "dev:setup": "turbo -F @uni-exam-sys/backend dev:setup",
    "seed:superadmin": "turbo -F @uni-exam-sys/backend seed:superadmin"
  },
  "dependencies": {
    "@uni-exam-sys/env": "workspace:*",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@uni-exam-sys/config": "workspace:*",
    "turbo": "^2.9.16",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.10"
}
